# Neutron ML Pipeline - Environment Variables
# Copy to .env and customize

# Temporal Configuration
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TASK_QUEUE=ml-pipeline-queue

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000

# Ray Configuration
RAY_ADDRESS=  # Leave empty for local mode, "auto" for cluster
RAY_NUM_CPUS=0  # 0 = all available
RAY_NUM_GPUS=1

# Worker Configuration
MAX_CONCURRENT_ACTIVITIES=10
MAX_CONCURRENT_WORKFLOWS=5

# Cost Tracking
ML_GPU_COST_PER_HOUR=0.90  # A100 pricing

# CEREBRO Integration (GCP)
GCP_PROJECT_ID=gen-lang-client-0530325234
GCP_REGION=us-central1
GCP_BILLING_DATASET=billing_export

# Paths
CEREBRO_DATA_DIR=./data
CEREBRO_VECTOR_DB=./data/vector_db

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# Primary LLM Provider (anthropic, openai, deepseek, llamacpp)
LLM_PRIMARY_PROVIDER=anthropic

# Fallback chain (comma-separated, tries in order if primary fails)
LLM_FALLBACK_CHAIN=deepseek,openai,llamacpp

# Global LLM settings
LLM_ENABLE_RETRIES=true
LLM_ENABLE_CIRCUIT_BREAKER=true
LLM_LOG_REQUESTS=true

# Anthropic (Claude) Configuration
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_ENABLED=true
ANTHROPIC_TEMPERATURE=0.3
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_TIMEOUT=30.0
ANTHROPIC_MAX_RETRIES=3

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ENABLED=true
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=1024
OPENAI_TIMEOUT=30.0
OPENAI_MAX_RETRIES=3

# DeepSeek Configuration
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_ENABLED=true
DEEPSEEK_TEMPERATURE=0.3
DEEPSEEK_MAX_TOKENS=1024
DEEPSEEK_TIMEOUT=30.0
DEEPSEEK_MAX_RETRIES=3

# llama.cpp Configuration (local inference)
LLAMACPP_URL=http://localhost:8081
LLAMACPP_MODEL=current-model
LLAMACPP_ENABLED=true
LLAMACPP_TEMPERATURE=0.3
LLAMACPP_MAX_TOKENS=1024
LLAMACPP_TIMEOUT=60.0

# =============================================================================
# NEXUS Platform Configuration
# =============================================================================

# Database
DATABASE_URL=postgresql://neutron:neutron@localhost/neutron

# Vault (secrets management)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=

# Decentralized Storage
IPFS_URL=http://localhost:5001
ARWEAVE_URL=https://arweave.net

# Feature Flags
ENABLE_BASTION=true
ENABLE_SMART_CONTRACTS=false
ENABLE_MEMORY=true
