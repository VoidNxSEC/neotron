# Sepolia RPC URL (get from Alchemy or Infura)
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# LendingProtocol Contract Address (deployed on Sepolia)
NEXT_PUBLIC_LENDING_PROTOCOL_ADDRESS=0x35fF603BD286E287f932356316271D59a4ADa779

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID
